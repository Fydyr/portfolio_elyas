# Nom du projet (utilisé pour les noms de conteneurs et Traefik)
NAME=portfolio

# Identifiants MySQL
MYSQL_DATABASE=portfolio
MYSQL_USERNAME=portfolio
MYSQL_PASSWORD=portfolio
MYSQL_ROOT_PASSWORD=rootpw

# Mets true pour forcer la régénération de includes/db.php au prochain boot
DB_REGENERATE=false

# Compte admin de base : créé automatiquement au premier boot si la table user est vide.
# Une fois créé, modifier ADMIN_PASSWORD ici n'a aucun effet (à changer via l'admin du site).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
